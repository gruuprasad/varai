{
  "name": "varai",
  "version": "0.0.0",
  "description": "Local-first build-state reports for AI-assisted software projects.",
  "type": "module",
  "private": true,
  "bin": {
    "varai": "./bin/varai.js"
  },
  "scripts": {
    "audit:example": "node ./bin/varai.js audit --repo ./examples/golden/todo-partial/app --intent ./examples/golden/todo-partial/intent.md --out ./.varai/example-report.md",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.20.8"
  }
}
